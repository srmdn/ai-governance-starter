#!/usr/bin/env sh
# Pre-commit hook: blocks AI attribution lines and sensitive data from being committed.
# Install: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
set -eu

PASS=0

# ── 1. AI attribution check ────────────────────────────────────────────────────

COMMIT_MSG_FILE=".git/COMMIT_EDITMSG"

if [ -f "$COMMIT_MSG_FILE" ]; then
  AI_PATTERN="(Co-authored-by:[[:space:]]*(Claude|ChatGPT)|Generated with Claude Code|Generated by[[:space:]].+)"
  if grep -E "$AI_PATTERN" "$COMMIT_MSG_FILE" >/dev/null 2>&1; then
    echo "[pre-commit] Blocked: banned AI attribution line found in commit message."
    echo
    echo "Remove these lines before committing:"
    grep -En "$AI_PATTERN" "$COMMIT_MSG_FILE" | sed 's/^/  /'
    echo
    echo "See docs/AI-COMMIT-CLEANUP.md for cleanup steps."
    PASS=1
  fi
fi

# ── 2. .env file check ────────────────────────────────────────────────────────

ENV_FILES=
if [ -n "$ENV_FILES" ]; then
  echo "[pre-commit] Blocked: .env file(s) staged for commit:"
  echo "$ENV_FILES" | sed 's/^/  /'
  echo
  echo "Add to .gitignore and unstage: git restore --staged <file>"
  PASS=1
fi

# ── 3. Sensitive filename check ───────────────────────────────────────────────

SENSITIVE_FILES=
if [ -n "$SENSITIVE_FILES" ]; then
  echo "[pre-commit] Blocked: sensitive file(s) staged for commit:"
  echo "$SENSITIVE_FILES" | sed 's/^/  /'
  echo
  echo "Unstage: git restore --staged <file>"
  PASS=1
fi

# ── 4. Hardcoded secret pattern check ────────────────────────────────────────
# Scans staged file content for common secret patterns.

SECRET_PATTERN="(password|passwd|secret|api_key|apikey|access_token|auth_token|private_key)[[:space:]]*[:=][[:space:]]*['\"][^'\"]{6,}['\"]"
MATCHED=
if [ -n "$MATCHED" ]; then
  echo "[pre-commit] Warning: possible hardcoded secret detected in staged changes:"
  echo "$MATCHED" | sed 's/^/  /' | head -10
  echo
  echo "Review the above. If intentional, use environment variables instead."
  echo "If a false positive, proceed with: git commit --no-verify (use sparingly)."
  PASS=1
fi

# ── Result ────────────────────────────────────────────────────────────────────

exit $PASS
